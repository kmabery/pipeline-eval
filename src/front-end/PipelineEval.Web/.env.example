# Vite env (copy to .env.local). Public SPA config only — never put secrets here.
#
# Local dev server and API proxy ports are driven by the repository root `.env` (LOCAL_WEB_PORT, LOCAL_API_PORT).
# See the repo `/.env.example`.

VITE_API_URL=

# Set all three to enable login in the SPA (production: GitHub Actions sets these from Terraform outputs).
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=us-east-1

# Playwright deployed E2E — read by playwright.config.ts and tests/e2e specs. Set locally or via GitHub Actions secrets.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_BASE_URL=
