{
  "Observability": {
    "ApplicationName": "spruce-next",
    "SubSystem": "PipelineEval",
    "ServiceName": "PipelineEval.Gateway",
    "ApiKey": "",
    "UseLocal": true,
    "OtlpEndpoint": "https://ingress.us2.coralogix.com:443",
    "OtlpHeaders": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Aws": {
    "SsmParameterPrefix": ""
  },
  "Gateway": {
    "SsmReverseProxyParameter": ""
  },
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "api",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "d1": {
            "Address": "http://127.0.0.1:5101/"
          }
        }
      }
    }
  }
}
